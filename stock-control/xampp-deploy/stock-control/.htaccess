<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /stock-control/

    # Pasar el header Authorization a PHP (XAMPP/Windows lo elimina por defecto)
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Las rutas /api/* las maneja PHP directamente (archivos reales)
    RewriteRule ^api/ - [L]

    # Archivos y carpetas que existen se sirven tal cual
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Todo lo demás va al index.html (React SPA routing)
    RewriteRule . index.html [L]
</IfModule>

# Cabeceras de seguridad básicas
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
</IfModule>
