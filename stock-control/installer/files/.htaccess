<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /stock-control/

    # Pasar el header Authorization a PHP (XAMPP/Windows lo elimina por defecto)
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Las rutas /api/* las maneja PHP directamente (archivos reales)
    RewriteRule ^api/ - [L]

    # Archivos y carpetas que existen se sirven tal cual
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Todo lo demás va al index.html (React SPA routing)
    RewriteRule . index.html [L]
</IfModule>

# Cabeceras de seguridad básicas
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"

    # index.html nunca se cachea para que el navegador siempre cargue el bundle JS correcto
    <FilesMatch "^index\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </FilesMatch>

    # Los assets tienen hash en el nombre → se pueden cachear largo tiempo
    <FilesMatch "\.(js|css)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>
