Options -Indexes
RewriteEngine On

# Pasar Authorization header a PHP (necesario en XAMPP/Windows)
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Servir archivos estáticos del dist directamente
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Todo lo demás va al backend
RewriteRule ^(.*)$ backend/index.php [QSA,L]
