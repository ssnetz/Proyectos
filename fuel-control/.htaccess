RewriteEngine On

# Pasar Authorization header a PHP (necesario en XAMPP)
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Si el archivo existe, servirlo directamente
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Todo lo demás va al backend/index.php
RewriteRule ^ backend/index.php [L]
